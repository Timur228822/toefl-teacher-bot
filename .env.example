# ── Required ───────────────────────────────────────────────
BOT_TOKEN=

# ── Database (Scalingo sets DATABASE_URL automatically) ────
DATABASE_URL=

# ── Ollama (LLM backend) ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Whisper (local STT) ────────────────────────────────────
WHISPER_MODEL=base

# ── App ────────────────────────────────────────────────────
LOG_LEVEL=INFO
ADMIN_IDS=[]
